{
  "name": "tiny-todo-list",
  "displayName": "Tiny TODO List",
  "description": "A simple TODO list with grouping, keyboard navigation, and webview UI",
  "version": "0.1.0",
  "publisher": "bbjyzzwwy",
  "author": "bbjyzzwwy",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/bbjyzzwwy/Tiny-TODO-List.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:tiny-todo-list-treeview"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tiny-todo-list",
          "title": "Tiny TODO List",
          "icon": "resources/activity-icon.svg"
        }
      ]
    },
    "views": {
      "tiny-todo-list": [
        {
          "type": "webview",
          "id": "tiny-todo-list-treeview",
          "name": "TODO List"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0"
  }
}
